{
  "debugger": {
    "dock": "left"
  },
  "git_panel": {
    "tree_view": true
  },
  "agent_servers": {
    "opencode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
      "default_model": "anthropic/claude-opus-4-5"
    },
    "claude": {
      "default_mode": "bypassPermissions",
      "default_model": "default"
    }
  },
  "context_servers": {
    "ios-control": {
      "enabled": true,
      "remote": false,
      "command": "npx",
      "args": ["-y", "ios-control-mcp"]
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": ""
      }
    },
    "mcp-server-figma": {
      "enabled": true,
      "settings": {
        "figma_api_key": ""
      }
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "show_turn_stats": true
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "hide_hidden": false,
    "hide_root": false,
    "auto_reveal_entries": true,
    "indent_size": 14.0,
    "folder_icons": true,
    "entry_spacing": "standard"
  },
  "tabs": {
    "file_icons": true
  },
  "title_bar": {
    "show_branch_icon": false
  },
  "auto_install_extensions": {
    "biome": true,
    "catppuccin-icons": true,
    "codebook": true,
    "csharp": true,
    "docker-compose": true,
    "dockerfile": true,
    "editorconfig": true,
    "git-firefly": true,
    "html": true,
    "java": true,
    "kotlin": true,
    "log": true,
    "make": true,
    "mcp-server-context7": true,
    "mcp-server-figma": true,
    "nix": true,
    "prisma": true,
    "proto": true,
    "pylsp": true,
    "python-requirements": true,
    "scss": true,
    "snazzy": true,
    "swift": true,
    "toml": true,
    "wakatime": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "buffer_font_family": "VictorMono Nerd Font Mono",
  "buffer_font_size": 14,
  "terminal": {
    "font_family": "VictorMono Nerd Font Mono"
  },
  "icon_theme": {
    "dark": "Catppuccin Macchiato",
    "light": "Catppuccin Latte",
    "mode": "system"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": {
    "dark": "Snazzy Theme - blurred",
    "light": "One Light",
    "mode": "system"
  },
  "ui_font_family": "VictorMono Nerd Font Mono",
  "ui_font_size": 14,
  "indent_guides": {
    "active_line_width": 2,
    "background_coloring": "indent_aware",
    "coloring": "indent_aware",
    "line_width": 1
  },
  "colorize_brackets": true,
  "experimental.theme_overrides": {
    "syntax": {
      "keyword": {
        "font_style": "italic"
      },
      "type": {
        "font_style": "italic"
      },
      "function": {
        "font_style": "italic"
      }
    }
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null
    }
  }
}
